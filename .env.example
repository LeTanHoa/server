PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/spotify_mini
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Local storage (default): place MP3s under server/storage/audio and covers under server/storage/covers
# Set STORAGE_MODE=s3 to use AWS S3 instead
STORAGE_MODE=local
LOCAL_AUDIO_DIR=./storage/audio
LOCAL_COVERS_DIR=./storage/covers

# AWS S3 (only when STORAGE_MODE=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_AUDIO_PREFIX=audio/
# S3_COVER_PREFIX=covers/

# Public URL of this API (used when frontend builds stream URLs)
API_PUBLIC_URL=http://localhost:5000
